{
  "manifest_version": 3,
  "name": "Swagger Boost",
  "version": "0.2.0",
  "description": "Adds a button to Swagger UI that authorizes using a JWT cookie from a configured domain.",
  "permissions": ["cookies", "scripting", "storage"],
  "optional_host_permissions": ["https://*/*"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  }
}
